{
  "name": "helpdog",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "npm run dev --prefix server",
    "dev:all": "npm run db:setup --prefix server && concurrently -k -n web,api -c cyan,magenta \"npm run dev\" \"npm run dev:api\"",
    "build": "vue-tsc -b && vite build",
    "build:api": "npm run build --prefix server",
    "preview": "vite preview",
    "db:setup": "npm run db:setup --prefix server"
  },
  "dependencies": {
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vue-tsc": "^3.3.5"
  }
}
